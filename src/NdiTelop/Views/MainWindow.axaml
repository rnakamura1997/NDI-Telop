<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NdiTelop.ViewModels"
        xmlns:ctrl="using:NdiTelop.Controls"
        xmlns:i="using:Avalonia.Xaml.Interactivity"
        xmlns:core="using:Avalonia.Xaml.Interactions.Core"
        xmlns:conv="using:NdiTelop.Converters"
        xmlns:ac="using:Avalonia.Controls"
        x:Class="NdiTelop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280" Height="720"
        Title="NdiTelop">
  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <Window.Resources>
    <conv:StringToColorConverter x:Key="StringToColorConverter" />
  </Window.Resources>
  <Grid ColumnDefinitions="250,*,360" RowDefinitions="*,Auto">
    <!-- Left Column: Preset List and Controls -->
    <StackPanel Grid.Column="0" Margin="10" Spacing="5">
      <Button Content="Load Presets" Command="{Binding LoadPresetsCommand}" HorizontalAlignment="Stretch" />
      <Button Content="Save Selected" Command="{Binding SaveSelectedPresetCommand}" HorizontalAlignment="Stretch" />
      <Button Content="Delete Selected" Command="{Binding DeleteSelectedPresetCommand}" HorizontalAlignment="Stretch" />
      <Button Content="Import Presets" Click="ImportPresetsButton_OnClick" HorizontalAlignment="Stretch" Margin="0,6,0,0" />
      <Button Content="Export Selected" Click="ExportSelectedPresetButton_OnClick" HorizontalAlignment="Stretch" />
      <Button Content="Export All" Click="ExportAllPresetsButton_OnClick" HorizontalAlignment="Stretch" />
      <Button Content="Show Preset" Command="{Binding ShowPresetCommand}" CommandParameter="{Binding SelectedPreset}" HorizontalAlignment="Stretch" Margin="0,10,0,0" />
      <Button Content="⚙ 設定" Click="OpenSettingsButton_OnClick" HorizontalAlignment="Stretch" Margin="0,6,0,0" />
      <ListBox x:Name="PresetListBox"
               ItemsSource="{Binding Presets}"
               SelectedItem="{Binding SelectedPreset}"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Margin="0,10,0,0">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <!-- Center Column: Preview Area -->
    <Border Grid.Column="1" Margin="10" BorderBrush="#333" BorderThickness="1" Background="Black">
      <ctrl:PreviewCanvas Preset="{Binding SelectedPreset}" NdiConfig="{Binding NdiConfig}" />
    </Border>

    <!-- Right Column: Preset Editor and Overlay Manager -->
    <ScrollViewer Grid.Column="2" Margin="10" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="6">
      <TextBlock Text="Preset Editor" FontWeight="Bold" Margin="0,0,0,5" />
      <TextBlock Text="Name:" />
      <TextBox Text="{Binding SelectedPreset.Name}" />
      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
        <TextBlock Text="Text Lines" FontWeight="SemiBold" VerticalAlignment="Center" />
        <Button Content="Add Line" Command="{Binding AddTextLineCommand}" />
      </StackPanel>
      <ListBox ItemsSource="{Binding SelectedPreset.TextLines}" MinHeight="280">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6">
              <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Line Text" Width="70" VerticalAlignment="Center" />
                  <TextBox Text="{Binding Text, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Font" Width="70" VerticalAlignment="Center" />
                  <ComboBox ItemsSource="{Binding DataContext.AvailableFontFamilies, RelativeSource={RelativeSource AncestorType=Window}}"
                            SelectedItem="{Binding FontFamily, Mode=TwoWay}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Size" Width="70" VerticalAlignment="Center" />
                  <TextBox Text="{Binding FontSize, Mode=TwoWay}" Width="80" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="Color" Width="70" VerticalAlignment="Center" />
                  <ac:ColorPicker Color="{Binding Color, Mode=TwoWay, Converter={StaticResource StringToColorConverter}}" HorizontalAlignment="Stretch" />
                </StackPanel>
                <Button Content="Remove" HorizontalAlignment="Right"
                        Command="{Binding DataContext.RemoveTextLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}" />
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
      <TextBlock Text="Transition Type:" />
      <ComboBox ItemsSource="{Binding AvailableTransitionTypes}"
                SelectedItem="{Binding SelectedPreset.Animation.InType, Mode=TwoWay}" />
      <TextBlock Text="Auto Clear (seconds):" />
      <TextBox Text="{Binding SelectedPreset.AutoClearSeconds}" />

      <TextBlock Text="Overlay Manager" FontWeight="Bold" Margin="0,10,0,5" />
      <Button Content="画像をインポート" Click="ImportImageButton_OnClick" HorizontalAlignment="Stretch" Margin="0,0,0,6" />
      <ListBox ItemsSource="{Binding SelectedPreset.Overlays}" MinHeight="260">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <Border BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6">
              <StackPanel Spacing="4">
                <TextBlock Text="{Binding Path}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                <CheckBox Content="表示" IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                  <TextBlock Text="Opacity" VerticalAlignment="Center" />
                  <Slider Minimum="0" Maximum="1" Value="{Binding Opacity, Mode=TwoWay}" TickFrequency="0.05" IsSnapToTickEnabled="False" Width="130" />
                  <TextBlock Text="{Binding Opacity, StringFormat={}{0:F2}}" Width="40" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>

      <Button Content="Render Preview" Command="{Binding RenderPreviewCommand}" HorizontalAlignment="Stretch" Margin="0,10,0,0" />

      </StackPanel>
    </ScrollViewer>

    <!-- Status Bar / Log Viewer -->
    <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#222" Padding="6">
      <StackPanel Spacing="4">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="10" Height="10" CornerRadius="5" Background="{Binding NdiOutputStatusColor}" VerticalAlignment="Center" />
          <TextBlock Text="NDI Output:" Foreground="#CFCFCF" FontSize="11" />
          <TextBlock Text="{Binding NdiOutputStatus}" Foreground="White" FontWeight="Bold" FontSize="11" />
        </StackPanel>
        <TextBlock Text="{Binding Status}" Foreground="White" FontWeight="SemiBold" />
        <ItemsControl ItemsSource="{Binding RecentLogs}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Foreground="#CFCFCF" FontSize="11" TextTrimming="CharacterEllipsis" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>
  </Grid>
</Window>
