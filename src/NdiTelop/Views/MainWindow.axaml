<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NdiTelop.Views.MainWindow"
        Width="1200" Height="720" Title="NdiTelop Phase 1a">
  <Grid ColumnDefinitions="300,*" RowDefinitions="*,Auto" Margin="12">
    <StackPanel Grid.Column="0" Spacing="8">
      <Button Content="Load Presets" Command="{Binding LoadCommand}" MinHeight="44" />
      <Button Content="Render Preview" Command="{Binding RenderPreviewCommand}" MinHeight="44" />
      <ListBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}">
        <ListBox.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding Name}" />
          </DataTemplate>
        </ListBox.ItemTemplate>
      </ListBox>
    </StackPanel>

    <Border Grid.Column="1" Background="#202020" Margin="12,0,0,0" CornerRadius="6">
      <TextBlock Text="Preview Area" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>

    <TextBlock Grid.ColumnSpan="2" Grid.Row="1" Text="{Binding Status}" Margin="0,8,0,0" />
  </Grid>
</Window>
